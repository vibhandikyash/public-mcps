{
  "name": "git-insights-mcp",
  "version": "0.1.0",
  "description": "MCP server for local-git analytics: contributor stats, file churn, ownership maps, and conventional-commit changelog generation.",
  "type": "module",
  "bin": {
    "git-insights-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "git",
    "analytics",
    "changelog",
    "contributors",
    "churn",
    "ownership",
    "conventional-commits",
    "ai"
  ],
  "author": "Yashvi Bhandik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibhandikyash/public-mcps.git",
    "directory": "git-insights-mcp"
  },
  "bugs": {
    "url": "https://github.com/vibhandikyash/public-mcps/issues"
  },
  "homepage": "https://github.com/vibhandikyash/public-mcps/tree/main/git-insights-mcp",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
